# Copiar a .env y completar.

# --- Base de datos (Postgres: Neon o Supabase) ---
# DATABASE_URL = conexión con POOLER (la usa la app en serverless).
# DIRECT_URL   = conexión DIRECTA sin pooler (la usan las migraciones).
# Si no usás pooler, pueden ser la misma URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth ---
# Secreto para firmar JWT de sesión y challenges. Generar uno fuerte para prod:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambiame-por-un-secreto-fuerte"

# --- Lightning (Alby Hub / NWC) ---  [necesario desde Semana 1: pagos]
# Cadena de conexión NWC del wallet de Luna Negra (Alby Hub).
# NWC_CONNECTION_STRING="nostr+walletconnect://<pubkey>?relay=wss://...&secret=..."

# --- Admin ---
# Pubkey (hex) del admin que aprueba juegos en /admin.
# Si se deja vacío, en dev cualquier usuario logueado puede aprobar.
# ADMIN_PUBKEY="<tu-pubkey-hex>"

# --- Subida de imágenes (Vercel Blob) ---
# Se crea solo al activar Blob Storage (PÚBLICO) en el dashboard de Vercel.
# Sin esto, la subida de imágenes se desactiva (igual podés pegar URLs).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Rate limiting (Upstash Redis) — recomendado en prod ---
# Sin esto, el rate-limit usa memoria (no se comparte entre instancias serverless).
# Crear un Redis gratis en upstash.com y copiar las credenciales REST.
# UPSTASH_REDIS_REST_URL="https://....upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# --- Apuestas / Escrow (Fase C) ---
# Identidad Nostr de Luna Negra (server) para firmar el contrato de la apuesta.
# Generar: node -e "const {generateSecretKey,nip19}=require('nostr-tools'); console.log(nip19.nsecEncode(generateSecretKey()))"
# LUNA_NEGRA_NSEC="nsec1..."
# Límites de la beta (sats) y fee de Luna Negra (%):
# BET_MIN_SATS="5"
# BET_MAX_SATS="100"
# BET_FEE_PCT="5"
