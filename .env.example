# Copiar a .env y completar.

# --- General ---
# URL pública canónica de la tienda. Se usa para los links en los anuncios de
# juegos en Nostr. Si falta, se infiere del request (ok en dev/previews).
# NEXT_PUBLIC_SITE_URL="https://lunanegra.app"

# --- Base de datos (Postgres: Neon o Supabase) ---
# DATABASE_URL = conexión con POOLER (la usa la app en serverless).
# DIRECT_URL   = conexión DIRECTA sin pooler (la usan las migraciones).
# Si no usás pooler, pueden ser la misma URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth ---
# Secreto para firmar JWT de sesión y challenges. Generar uno fuerte para prod:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambiame-por-un-secreto-fuerte"

# --- Login por email (magic link, cuentas custodiales) ---
# Resend envía el email con el link de acceso. Sin RESEND_API_KEY, en dev el link
# se loguea en la consola del server (suficiente para probar el flujo).
# Crear una key en resend.com y verificar el dominio del remitente.
# RESEND_API_KEY="re_..."
# Remitente del email (debe ser de un dominio verificado en Resend).
# Default: "Luna Negra <onboarding@resend.dev>" (solo sirve para pruebas).
# EMAIL_FROM="Luna Negra <hola@lunanegra.app>"
# NOTA: la nsec custodial se cifra con ORACLE_ENC_KEY (ver más abajo). Esa var
# pasa a ser OBLIGATORIA si habilitás el login por email en producción.

# --- Lightning (Alby Hub / NWC) ---  [necesario desde Semana 1: pagos]
# Cadena de conexión NWC del wallet de Luna Negra (Alby Hub).
# NWC_CONNECTION_STRING="nostr+walletconnect://<pubkey>?relay=wss://...&secret=..."

# --- API de devs: firma de tokens (ES256 / JWKS) ---
# Firma los tokens de acceso (entitlement) e invitación (sala) que el game server
# valida OFFLINE contra /.well-known/jwks.json. OBLIGATORIO en producción
# (en serverless, sin esto cada instancia generaría una clave distinta).
# Generar una JWK privada ES256:
#   node -e "const{generateKeyPair,exportJWK}=require('jose');(async()=>{const{privateKey}=await generateKeyPair('ES256',{extractable:true});const j=await exportJWK(privateKey);j.kid='ln-1';j.alg='ES256';j.use='sig';console.log(JSON.stringify(j))})()"
# LN_SIGNING_JWK='{"kty":"EC","crv":"P-256","x":"...","y":"...","d":"...","kid":"ln-1","alg":"ES256","use":"sig"}'
# Issuer (iss) de los tokens; el game server lo valida. Default: "luna-negra".
# LN_ISSUER="luna-negra"

# --- Admin ---
# Pubkey (hex) del admin que aprueba juegos en /admin.
# Si se deja vacío, en dev cualquier usuario logueado puede aprobar.
# ADMIN_PUBKEY="<tu-pubkey-hex>"

# --- Subida de imágenes (Vercel Blob) ---
# Se crea solo al activar Blob Storage (PÚBLICO) en el dashboard de Vercel.
# Sin esto, la subida de imágenes se desactiva (igual podés pegar URLs).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Rate limiting (Upstash Redis) — recomendado en prod ---
# Sin esto, el rate-limit usa memoria (no se comparte entre instancias serverless).
# Crear un Redis gratis en upstash.com y copiar las credenciales REST.
# UPSTASH_REDIS_REST_URL="https://....upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# --- Apuestas / Escrow (Fase C) ---
# Identidad Nostr de Luna Negra (server) para firmar el contrato de la apuesta.
# Generar: node -e "const {generateSecretKey,nip19}=require('nostr-tools'); console.log(nip19.nsecEncode(generateSecretKey()))"
# LUNA_NEGRA_NSEC="nsec1..."
# Clave maestra (32 bytes) para CIFRAR la clave del oráculo gestionado por
# proveedor (AES-256-GCM) — con ella Luna Negra firma resultados/actividad por
# API key, sin que el game server tenga clave Nostr. Generar:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Tras configurarla en prod, backfilleá los proveedores existentes:
#   node prisma/scripts/backfill-oracle-keys.mjs
# ORACLE_ENC_KEY="<64 chars hex o base64 de 32 bytes>"
# Límites de la beta (sats) y fee de Luna Negra (%):
# BET_MIN_SATS="5"
# BET_MAX_SATS="100"
# BET_FEE_PCT="5"
# Tick del escrow (Upstash QStash). Schedule recurrente → POST /api/escrow/tick.
# Firmas para verificar que el request viene de QStash (en el dashboard de QStash):
# QSTASH_CURRENT_SIGNING_KEY="sig_..."
# QSTASH_NEXT_SIGNING_KEY="sig_..."
# Token de PUBLICACIÓN de QStash (para entregar webhooks a proveedores con
# reintentos). Sin esto, en dev los webhooks se entregan con fetch directo.
# QSTASH_TOKEN="..."

# --- Monitoreo de errores (Sentry) — recomendado en prod ---
# Sin DSN, Sentry queda inerte (no envía nada). Crear proyecto en sentry.io.
# El DSN va en DOS vars con el mismo valor: server y cliente (NEXT_PUBLIC_).
# SENTRY_DSN="https://...@oXXXX.ingest.sentry.io/XXXX"
# NEXT_PUBLIC_SENTRY_DSN="https://...@oXXXX.ingest.sentry.io/XXXX"
# Tracing (performance) apagado por defecto. 0–1 para muestrear latencias:
# SENTRY_TRACES_SAMPLE_RATE="0"
# Subida de source maps en el build (stacktraces legibles). Solo si están las 3:
# SENTRY_ORG="tu-org"
# SENTRY_PROJECT="luna-negra"
# SENTRY_AUTH_TOKEN="sntrys_..."
