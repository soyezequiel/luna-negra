{
  "openapi": "3.1.0",
  "info": {
    "title": "Luna Negra · API para desarrolladores",
    "version": "1.0.0",
    "description": "Contrato público de Luna Negra para desarrolladores de juegos.\n\nAutenticación: los tokens de acceso (entitlement) e invitación (sala) van en el header `Authorization: Bearer <token>`. Son JWT firmados con ES256: podés validarlos **offline** con la clave pública de `/.well-known/jwks.json` (recomendado) o contra los endpoints `/verify` de abajo.\n\nErrores: forma estándar `{ \"error\": { \"code\", \"message\" } }` con el status HTTP correspondiente."
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": { "host": { "default": "luna-negra-three.vercel.app" } }
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token emitido por Luna Negra (entitlement o invite)."
      },
      "apiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key del proveedor (`ln_sk_…`), creada en el panel /provider."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string", "example": "MISSING_TOKEN" },
              "message": { "type": "string" }
            },
            "required": ["code", "message"]
          }
        }
      },
      "WebhookConfig": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "nullable": true,
            "description": "URL de webhook configurada (null si no hay)."
          },
          "secret": {
            "type": "string",
            "nullable": true,
            "description": "Secreto de firma HMAC (whsec_…); null si no hay URL."
          }
        }
      },
      "EntitlementVerify": {
        "type": "object",
        "properties": {
          "valid": { "type": "boolean" },
          "npub": { "type": "string" },
          "gameId": { "type": "string" },
          "slug": { "type": "string" }
        },
        "required": ["valid"]
      },
      "RoomVerify": {
        "type": "object",
        "properties": {
          "valid": { "type": "boolean" },
          "npub": { "type": "string", "description": "Identidad estable del jugador" },
          "pubkey": { "type": "string", "description": "Pubkey hex (identidad estable)" },
          "displayName": { "type": ["string", "null"], "description": "Solo presentación" },
          "avatarUrl": { "type": ["string", "null"], "description": "Solo presentación" },
          "gameId": { "type": "string" },
          "slug": { "type": "string" },
          "roomId": { "type": "string" },
          "host": { "type": "boolean", "description": "true = creador de la sala" },
          "hostNpub": { "type": ["string", "null"], "description": "Host original de la sala" },
          "hostPubkey": { "type": ["string", "null"], "description": "Host original (pubkey hex)" },
          "expiresAt": { "type": ["string", "null"], "format": "date-time", "description": "Caducidad de la invitación" }
        },
        "required": ["valid"]
      },
      "PlayerProfile": {
        "type": "object",
        "properties": {
          "npub": { "type": "string" },
          "pubkey": { "type": "string" },
          "displayName": { "type": ["string", "null"] },
          "avatarUrl": { "type": ["string", "null"] }
        }
      },
      "PresenceMember": {
        "type": "object",
        "properties": {
          "clientId": { "type": "string" },
          "npub": { "type": "string" },
          "host": { "type": "boolean" },
          "score": { "type": "integer" },
          "name": { "type": ["string", "null"] },
          "avatar": { "type": ["string", "null"] }
        }
      },
      "Jwks": {
        "type": "object",
        "properties": {
          "keys": { "type": "array", "items": { "type": "object" } }
        }
      },
      "CreateBetRequest": {
        "type": "object",
        "required": ["gameId", "participants", "stakeSats"],
        "properties": {
          "gameId": { "type": "string" },
          "participants": {
            "type": "array",
            "items": { "type": "string", "description": "npub" },
            "minItems": 2
          },
          "stakeSats": {
            "type": "integer",
            "description": "Monto por jugador (sats). Debe estar entre minStakeSats y maxStakeSats; fuera de rango → STAKE_OUT_OF_RANGE."
          },
          "victoryCondition": { "type": "string" },
          "roomId": { "type": "string", "description": "Sala multijugador del juego (correlación, opcional)" },
          "metadata": { "type": "object", "description": "Metadata libre; se persiste y vuelve en GET y en cada webhook" }
        }
      },
      "BetEconomics": {
        "type": "object",
        "description": "Economía de la apuesta (sats).",
        "properties": {
          "stakeSats": { "type": "integer", "description": "Stake por jugador" },
          "potTargetSats": { "type": "integer", "description": "Pozo total cuando esté completo (stake × participantes)" },
          "feePct": { "type": "integer", "description": "Comisión de Luna Negra (%)" },
          "feeBps": { "type": "integer", "description": "Comisión en basis points (feePct × 100)" },
          "feeSats": { "type": "integer", "description": "Comisión absoluta" },
          "netPayoutSats": { "type": "integer", "description": "Pago neto a repartir entre ganadores (pozo − comisión)" }
        }
      },
      "CreateBetResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/BetEconomics" },
          {
            "type": "object",
            "properties": {
              "betId": { "type": "string" },
              "contractEventId": { "type": ["string", "null"], "description": "Evento Nostr del contrato firmado" },
              "depositDeadline": { "type": "string", "format": "date-time" },
              "roomId": { "type": ["string", "null"] },
              "metadata": { "type": ["object", "null"] }
            }
          }
        ]
      },
      "BetParticipantView": {
        "type": "object",
        "properties": {
          "npub": { "type": "string" },
          "depositStatus": { "type": "string", "enum": ["pending", "paid", "refunded", "failed"] },
          "result": { "type": "string", "enum": ["pending", "won", "lost", "tie"] },
          "payoutStatus": { "type": "string" },
          "payoutSats": { "type": ["integer", "null"] }
        }
      },
      "BetDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/BetEconomics" },
          {
            "type": "object",
            "properties": {
              "betId": { "type": "string" },
              "gameId": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["pending_deposits", "funded", "settled", "cancelled", "expired", "refunded"]
              },
              "victoryCondition": { "type": "string" },
              "depositDeadline": { "type": ["string", "null"], "format": "date-time" },
              "resolveDeadline": { "type": ["string", "null"], "format": "date-time" },
              "potSats": { "type": "integer", "description": "Pozo depositado hasta ahora" },
              "participants": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/BetParticipantView" }
              },
              "roomId": { "type": ["string", "null"] },
              "metadata": { "type": ["object", "null"] },
              "contractEventId": { "type": ["string", "null"] },
              "resultEventId": { "type": ["string", "null"] }
            }
          }
        ]
      },
      "DepositHandle": {
        "type": "object",
        "description": "Cómo paga su stake un participante. Los handles son null si el depósito ya cerró (pagado, vencido o estado no abierto).",
        "properties": {
          "npub": { "type": "string" },
          "depositStatus": { "type": "string", "enum": ["pending", "paid", "refunded", "failed"] },
          "bolt11": { "type": ["string", "null"], "description": "Invoice Lightning fijo (BOLT11) por el stake" },
          "lnurl": { "type": ["string", "null"], "description": "LNURL-pay (bech32) equivalente" },
          "payUrl": { "type": ["string", "null"], "description": "Deep-link a la pantalla de pago de Luna Negra" }
        }
      },
      "BetDeposits": {
        "type": "object",
        "properties": {
          "betId": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending_deposits", "funded", "settled", "cancelled", "expired", "refunded"]
          },
          "stakeSats": { "type": "integer" },
          "potSats": { "type": "integer", "description": "Depositado hasta ahora" },
          "potTargetSats": { "type": "integer" },
          "depositsReceived": { "type": "integer" },
          "depositsTotal": { "type": "integer" },
          "depositDeadline": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Plazo para completar los depósitos; si vence sin completarse el pozo, se reembolsa y se cancela (bet.expired)."
          },
          "deposits": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DepositHandle" }
          }
        }
      },
      "WebhookEvent": {
        "type": "object",
        "description": "Cuerpo de un webhook. Cabeceras: X-LunaNegra-Event y X-LunaNegra-Signature (HMAC-SHA256 del cuerpo con el secreto del proveedor). Los eventos de apuesta incluyen roomId/metadata para correlación.",
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "purchase.completed",
              "bet.settled",
              "payout.sent",
              "deposit.received",
              "bet.funded",
              "bet.cancelled",
              "bet.expired",
              "bet.refunded"
            ]
          },
          "created": { "type": "string", "format": "date-time" },
          "data": { "type": "object" }
        }
      }
    }
  },
  "paths": {
    "/.well-known/jwks.json": {
      "get": {
        "summary": "Claves públicas (JWKS)",
        "description": "Clave pública ES256 para validar los tokens offline.",
        "tags": ["Tokens"],
        "responses": {
          "200": {
            "description": "Conjunto de claves",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Jwks" } }
            }
          }
        }
      }
    },
    "/api/v1/entitlements/verify": {
      "get": {
        "summary": "Verificar acceso (entitlement)",
        "description": "Confirma que el jugador compró el juego. Alternativa al verify offline con JWKS.",
        "tags": ["Entitlements"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Resultado de la introspección (token inválido → valid:false)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntitlementVerify" }
              }
            }
          },
          "400": {
            "description": "Falta el token",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/v1/rooms/verify": {
      "get": {
        "summary": "Verificar invitación a sala",
        "description": "Valida el invite token de un jugador que se une a una sala multijugador.",
        "tags": ["Multijugador"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Resultado de la introspección",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RoomVerify" }
              }
            }
          },
          "400": {
            "description": "Falta el token",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/v1/players/{npub}/profile": {
      "get": {
        "summary": "Perfil público de un jugador",
        "description": "Devuelve nombre y avatar (kind:0 cacheado) por npub, para refrescar la presentación sin depender del invite token. Público (CORS abierto).",
        "tags": ["Multijugador"],
        "parameters": [
          {
            "name": "npub",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil del jugador (displayName/avatarUrl pueden ser null)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlayerProfile" }
              }
            }
          },
          "400": {
            "description": "npub inválido",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/v1/rooms/{roomId}/presence": {
      "post": {
        "summary": "Heartbeat + roster de la sala",
        "description": "El cliente postea su puntaje cada ~2s; devuelve quién está en línea (con nombre/avatar).",
        "tags": ["Multijugador"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "clientId": { "type": "string", "description": "Id propio del cliente (distingue navegadores)" },
                  "score": { "type": "integer" },
                  "leave": { "type": "boolean", "description": "true para salir de la sala" }
                },
                "required": ["clientId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Roster de la sala",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "members": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/PresenceMember" }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token inválido para esta sala",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/v1/bets": {
      "post": {
        "summary": "Crear una apuesta (escrow)",
        "description": "El game server crea una apuesta; Luna Negra custodia el pozo y publica el contrato firmado en Nostr. Autenticación con API key del proveedor.",
        "tags": ["Apuestas"],
        "security": [{ "apiKeyAuth": [] }],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "description": "Clave única para reintentos seguros: un reintento con la misma key devuelve la respuesta original sin crear otra apuesta.",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBetRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Apuesta creada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateBetResponse" }
              }
            }
          },
          "401": {
            "description": "API key inválida",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "403": {
            "description": "El juego no es de tu proveedor",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/v1/bets/{id}": {
      "get": {
        "summary": "Estado y economía de una apuesta",
        "description": "Devuelve estado público, depósitos por participante, pozo, comisión y pago neto. Autenticación con API key del proveedor dueño.",
        "tags": ["Apuestas"],
        "security": [{ "apiKeyAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Estado de la apuesta",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/BetDetail" } }
            }
          },
          "401": {
            "description": "API key inválida",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "403": {
            "description": "La apuesta no es de tu proveedor (NOT_BET_OWNER)",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Apuesta no encontrada",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/api/v1/bets/{id}/deposits": {
      "get": {
        "summary": "Handles de pago por participante",
        "description": "Para cada participante devuelve cómo deposita su stake en escrow: bolt11 (invoice fijo), lnurl (LNURL-pay) y payUrl (deep-link a la pantalla de pago de Luna Negra). El plazo es `depositDeadline`. Autenticación con API key del proveedor dueño.",
        "tags": ["Apuestas"],
        "security": [{ "apiKeyAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Vista de depósitos con handles de pago",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/BetDeposits" } }
            }
          },
          "401": {
            "description": "API key inválida",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "403": {
            "description": "La apuesta no es de tu proveedor (NOT_BET_OWNER)",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Apuesta no encontrada",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/api/v1/bets/{id}/cancel": {
      "post": {
        "summary": "Cancelar una apuesta y reembolsar",
        "description": "Cancela una apuesta NO resuelta (pending_deposits o funded) y reembolsa los depósitos confirmados. Emite bet.cancelled + bet.refunded. Autenticación con API key del proveedor dueño.",
        "tags": ["Apuestas"],
        "security": [{ "apiKeyAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Cancelada (reembolsos en curso)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "status": { "type": "string", "example": "cancelled" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "API key inválida",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "403": {
            "description": "La apuesta no es de tu proveedor (NOT_BET_OWNER)",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Apuesta no encontrada",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "409": {
            "description": "No se puede cancelar (ya resuelta o estado inválido: ALREADY_RESOLVED / CANNOT_CANCEL)",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/api/v1/bets/{id}/result": {
      "post": {
        "summary": "Reportar el resultado de una apuesta",
        "description": "Dos caminos:\n\n1. **API key (recomendado):** `Authorization: Bearer ln_sk_…` + body `{ winners }` (array de npubs; vacío = empate/anulación). Luna Negra construye y firma el resultado con el oráculo gestionado del proveedor — el game server no toca Nostr.\n2. **Evento firmado (avanzado):** body `{ event }` con un evento Nostr firmado por el oráculo del proveedor (tags `bet`, `winner`). La firma se valida contra `oraclePubkey`.\n\nLuna Negra verifica el contrato (CONTRACT_MISMATCH) antes de pagar.",
        "tags": ["Apuestas"],
        "security": [{ "apiKeyAuth": [] }, {}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "description": "Camino API key: ganadores por npub.",
                    "properties": {
                      "winners": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "npubs ganadores; array vacío = empate/anulación (reembolso total)."
                      }
                    },
                    "required": ["winners"]
                  },
                  {
                    "type": "object",
                    "description": "Camino avanzado: evento Nostr firmado por el oráculo del proveedor.",
                    "properties": {
                      "event": { "type": "object", "description": "Evento Nostr firmado (tags bet, winner)" }
                    },
                    "required": ["event"]
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resuelta y pagada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "voided": { "type": "boolean", "description": "true si fue empate/anulación (reembolso)" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Firma inválida o API key inválida",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "403": {
            "description": "La API key no es del proveedor de la apuesta (FORBIDDEN) o firmante incorrecto (WRONG_SIGNER)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "409": {
            "description": "Estado inválido, CONTRACT_MISMATCH o ORACLE_NOT_PROVISIONED",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/v1/games/{slug}/activity": {
      "post": {
        "summary": "Publicar una nota en el feed de Actividad del juego",
        "description": "Publica una nota (kind:1, tag `lunanegra:game:<slug>`) en la pestaña Actividad. Auth = API key del proveedor; Luna Negra firma con el oráculo gestionado, así el game server no toca Nostr.",
        "tags": ["Apuestas"],
        "security": [{ "apiKeyAuth": [] }],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string", "description": "Texto de la nota (1–2000 chars)" }
                },
                "required": ["content"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Nota publicada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "eventId": { "type": "string" },
                    "pubkey": { "type": "string" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "El juego no es de tu proveedor (FORBIDDEN)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "409": {
            "description": "ORACLE_NOT_PROVISIONED",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/v1/provider/webhook": {
      "get": {
        "summary": "Leer la config de webhook del proveedor",
        "description": "Devuelve la URL y el secreto de firma (`whsec_…`) actuales del proveedor de la API key, sin rotarlos. Pensado para leer el secreto al arrancar el game server.",
        "tags": ["Webhooks"],
        "security": [{ "apiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Config actual",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WebhookConfig" }
              }
            }
          },
          "401": {
            "description": "INVALID_API_KEY",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      },
      "post": {
        "summary": "Registrar la URL de webhook y obtener/rotar el secreto",
        "description": "Auto-registro usando solo la API key (sin panel humano). Setea `webhookUrl` y devuelve el secreto de firma. Genera el secreto si no había, o lo ROTA (invalidando el anterior) si `regenerate:true`. Una `url` vacía/ausente borra URL y secreto. El secreto solo se devuelve por este endpoint al dueño de la key; nunca se loguea.",
        "tags": ["Webhooks"],
        "security": [{ "apiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "URL http(s) del webhook. Vacía/ausente borra la config."
                  },
                  "regenerate": {
                    "type": "boolean",
                    "description": "Si true, rota el secreto e invalida el anterior."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Config aplicada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WebhookConfig" }
              }
            }
          },
          "400": {
            "description": "INVALID_WEBHOOK_URL (la URL no empieza con http(s)://)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": {
            "description": "INVALID_API_KEY",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "429": {
            "description": "RATE_LIMITED",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "purchase.completed": {
