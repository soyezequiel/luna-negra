generator client {
  provider      = "prisma-client-js"
  // "native" para local + el target del runtime de Vercel (Amazon Linux, OpenSSL 3).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL: conexión con POOLER (para serverless en Vercel).
  // DIRECT_URL: conexión DIRECTA (sin pooler), usada por las migraciones.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  npub        String   @unique
  pubkey      String   @unique // hex
  // Cuentas custodiales (login por email con magic link): el usuario no trae una
  // identidad Nostr propia, así que Luna Negra le genera el keypair. `email` es
  // el identificador de login; `nsecEnc` es la clave privada cifrada en reposo
  // (AES-256-GCM, ver src/lib/crypto-vault.ts) que se le entrega al navegador al
  // loguear y se puede exportar desde el perfil. Null en cuentas Nostr normales.
  email       String?  @unique
  nsecEnc     String? // secret key cifrada (solo cuentas custodiales por email)
  displayName String?
  avatarUrl   String?
  lud16       String? // Lightning Address para cobrar payouts (override del kind:0)
  // Destino de cobros de premios/payouts: "address" = cascada lud16 (Luna Negra
  // → kind:0); "nwc" = el wallet NWC del usuario (vive sólo en su navegador), así
  // que el server fuerza withdraw_pending y el cliente reclama por LNURL-withdraw.
  payoutMethod String  @default("address")
  createdAt   DateTime @default(now())
  lastSeen    DateTime @default(now())
  // Última vez que lanzó/jugó un juego (ordena la lista de amigos: los que
  // jugaron alguna vez van arriba). Null = nunca jugó.
  lastPlayedAt DateTime?

  providers         Provider[]
  purchases         Purchase[]
  reviews           Review[]
  betParticipations BetParticipant[]
  ledgerEntries     LedgerEntry[]
}

model Provider {
  id               String   @id @default(cuid())
  ownerId          String
  owner            User     @relation(fields: [ownerId], references: [id])
  name             String
  lightningAddress String? // dirección Lightning para el payout (70%)
  status           String   @default("pending") // pending | approved
  webhookUrl       String? // URL para notificar eventos (purchase/bet/payout)
  webhookSecret    String? // secreto para firmar los webhooks (HMAC) — whsec_…
  // Oráculo gestionado: clave Nostr que Luna Negra custodia para firmar el
  // resultado/actividad en nombre del proveedor (así el game server solo usa su
  // API key). `oraclePubkey` (hex) es público y valida los eventos firmados;
  // `oracleSecretEnc` es el secreto cifrado en reposo (AES-256-GCM). Ver
  // src/lib/oracle-keys.ts y src/lib/crypto-vault.ts.
  oraclePubkey     String? // hex; contra esta clave se valida el evento de resultado
  oracleSecretEnc  String? // secreto cifrado (nunca se loguea ni se expone por API)
  createdAt        DateTime @default(now())

  games               Game[]
  bets                Bet[]
  apiKeys             ApiKey[]
  gamePresence        GamePresence[]
  gameInvites         GameInvite[]
  gameLaunchRequests  GameLaunchRequest[]
  gameLaunchListeners GameLaunchListener[]
}

// Presencia por-juego (proveedor), keyed por npub, TTL ~30s. La pobla el game
// server vía POST /api/v1/presence (Bearer API key). Distinta de RoomPresence,
// que es por sala/clientId y la maneja Luna Negra en su demo multijugador.
model GamePresence {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  npub       String
  status     String // "in-game" | "online" (clave reservada de presentación)
  roomId     String?
  stateJson  String? // bolsa libre del juego (JSON serializado): puntaje, vidas, equipo…
  expiresAt  DateTime // now + 30s
  updatedAt  DateTime @updatedAt

  @@unique([providerId, npub])
  @@index([providerId])
  @@index([expiresAt])
}

// Buzón de invitaciones a sala que el proveedor envía vía POST /api/v1/invites;
// Luna Negra se las muestra al invitado (toast in-app). TTL ~1h, como las
// invitaciones por DM existentes.
model GameInvite {
  id         String    @id @default(cuid())
  providerId String
  provider   Provider  @relation(fields: [providerId], references: [id])
  fromNpub   String
  toNpub     String
  roomId     String
  inviteUrl  String // URL del deploy del juego (externa), p. ej. .../?join=AB12
  createdAt  DateTime  @default(now())
  expiresAt  DateTime // now + 1h
  seenAt     DateTime?

  @@index([toNpub, expiresAt])
}

// Orden pendiente para que un juego YA abierto entre a una sala cuando el usuario
// aceptó una invitación en Luna Negra. La consume el game server vía API key.
model GameLaunchRequest {
  id          String    @id @default(cuid())
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id])
  npub        String
  roomId      String
  inviteToken String
  slug        String
  title       String
  gameUrl     String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?

  @@index([providerId, npub, expiresAt])
  @@index([expiresAt])
}

// Pestaña de juego viva que consulta ordenes pendientes. No alimenta NIP-38 ni
// la lista social de "jugando"; solo evita abrir otra pestaña al aceptar una
// invitación si el juego ya está escuchando.
model GameLaunchListener {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  npub       String
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime

  @@unique([providerId, npub])
  @@index([expiresAt])
}

// Claves de API del proveedor (auth server-to-server, ej. crear apuestas).
// Se guarda solo el hash; la clave en claro se muestra una sola vez al crearla.
model ApiKey {
  id         String    @id @default(cuid())
  providerId String
  provider   Provider  @relation(fields: [providerId], references: [id])
  name       String
  prefix     String // primeros chars, para mostrar (ej. "ln_sk_ab12cd")
  hash       String    @unique // sha256(key)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([providerId])
}

model Game {
  id                 String   @id @default(cuid())
  providerId         String
  provider           Provider @relation(fields: [providerId], references: [id])
  slug               String   @unique
  title              String
  description        String   @default("")
  categories         String[] @default([]) // slugs de categorías curadas (ver src/lib/categories.ts)
  priceSats          Int      @default(0) // 0 = gratis
  coverUrl           String?
  horizontalCoverUrl String?
  screenshots        String   @default("[]") // JSON array de URLs (portable SQLite/Postgres)
  gameUrl            String? // subdominio donde el proveedor hostea el juego
  status             String   @default("draft") // draft | in_review | published
  revenueShare       Int      @default(70) // % para el proveedor
  // Posteo raíz en Nostr (kind:1) que Luna Negra publica al aprobar el juego.
  // Comentarios y reseñas se cuelgan de aquí como respuestas (NIP-10).
  nostrEventId       String? // id del evento anuncio
  nostrPubkey        String? // pubkey de Luna Negra que firmó el anuncio (tag p de las respuestas)
  createdAt          DateTime @default(now())

  purchases Purchase[]
  reviews   Review[]
  bets      Bet[]
}

model Purchase {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  gameId       String
  game         Game      @relation(fields: [gameId], references: [id])
  amountSats   Int
  invoice      String? // bolt11
  paymentHash  String?
  status       String    @default("pending") // pending | paid | failed
  payoutStatus String    @default("none") // none | pending | paid | failed
  payoutHash   String?
  createdAt    DateTime  @default(now())
  paidAt       DateTime?

  @@unique([userId, gameId]) // un usuario posee un juego una sola vez (entitlement)
}

// Idempotencia de endpoints de dinero (header Idempotency-Key). Guarda la
// respuesta para devolverla en reintentos sin re-ejecutar la acción.
model IdempotencyKey {
  id         String   @id @default(cuid())
  scope      String // ej. providerId
  key        String
  statusCode Int? // null = en progreso (claim sin respuesta aún)
  response   String? // JSON del body
  createdAt  DateTime @default(now())

  @@unique([scope, key])
}

// Sala multijugador: registra al host original (identidad Nostr estable) para
// que los invitados sepan quién creó la sala, aunque el host se desconecte y
// la presencia efímera (RoomPresence) caduque. Una sala por (gameId, roomId).
model Room {
  id         String    @id @default(cuid())
  gameId     String
  roomId     String
  hostNpub   String
  hostPubkey String // hex
  // Latido del host: se sella al primer heartbeat del host. Sirve para no cerrar
  // la sala por "host ausente" antes de que el host haya llegado siquiera.
  hostSeenAt DateTime?
  // Si el host cierra el juego (leave explícito o presencia vencida) la sala se
  // cierra para siempre: nadie se readmite y los invitados reciben closed:true.
  closedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@unique([gameId, roomId])
  @@index([gameId])
}

// Presencia efímera de salas multijugador (demo). Polling + limpieza por TTL.
model RoomPresence {
  id        String   @id @default(cuid())
  roomId    String
  clientId  String // distingue navegadores/pestañas aunque compartan npub
  npub      String
  host      Boolean  @default(false)
  score     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, clientId])
  @@index([roomId])
}

// Estado compartido de una sala, para juegos SIN backend propio (Luna Negra
// hostea el "tablero común", estilo SetLobbyData de Steam). Bolsa key/value
// libre; la plataforma no interpreta su contenido. TTL corto: si nadie escribe
// por un rato, la sala se considera abandonada y se purga.
model RoomState {
  id        String   @id @default(cuid())
  roomId    String   @unique
  dataJson  String   @default("{}") // bolsa compartida (JSON serializado, last-write-wins por clave)
  version   Int      @default(0) // se incrementa en cada escritura compartida (CAS opcional / ETag)
  updatedAt DateTime @updatedAt
  expiresAt DateTime // now + TTL; se renueva en cada escritura

  @@index([expiresAt])
}

// Estado por jugador dentro de una sala (estilo SetLobbyMemberData de Steam): lo
// escribe el propio jugador con su invite token. Alimenta `members[]` del estado
// de la sala. TTL corto = roster vivo (cada POST actúa de heartbeat).
model RoomMemberState {
  id        String   @id @default(cuid())
  roomId    String
  npub      String
  stateJson String   @default("{}") // bolsa libre del jugador (JSON serializado)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime // now + TTL; se renueva en cada POST del jugador

  @@unique([roomId, npub])
  @@index([roomId])
  @@index([expiresAt])
}

// Marcador con nombre, genérico y por juego (el `name` lo elige el juego:
// "semanal", "clasico", …). OJO: un puntaje lo manda el CLIENTE y es
// FALSIFICABLE → sirve para MOSTRAR rankings (como Steam), NO para resolver
// apuestas (eso sigue viniendo del game server por /result).
model Leaderboard {
  id        String   @id @default(cuid())
  gameId    String
  name      String // lo elige el juego: "semanal", "clasico", …
  createdAt DateTime @default(now())
  scores    Score[]

  @@unique([gameId, name])
  @@index([gameId])
}

// Mejor puntaje por jugador en un marcador ("se queda el mejor": una fila por
// jugador). `updatedAt` marca cuándo fijó ese récord (filtro de la ventana week).
model Score {
  id            String      @id @default(cuid())
  leaderboardId String
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  npub          String
  score         Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([leaderboardId, npub])
  @@index([leaderboardId, score])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  rating    Int // 1-5
  body      String   @default("")
  createdAt DateTime @default(now())

  @@unique([userId, gameId]) // una reseña por usuario y juego
}

// Magic links de login por email ya canjeados. El token JWT trae un `jti` único;
// al canjearlo insertamos ese jti acá, y el unique constraint hace el consumo de
// un solo uso atómico (un segundo canje del mismo link choca y se rechaza). El
// barrido por `expiresAt` permite purgar filas viejas (el token ya no es válido).
model ConsumedMagicLink {
  jti       String   @id
  consumedAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// ───────────────────────── Apuestas / Escrow (Fase C) ─────────────────────────

model Bet {
  id               String    @id @default(cuid())
  gameId           String
  game             Game      @relation(fields: [gameId], references: [id])
  providerId       String
  provider         Provider  @relation(fields: [providerId], references: [id])
  // created | pending_deposits | ready | settling | settled |
  // refunding | cancelled_incomplete | cancelled_admin | refunded_timeout | voided
  status           String    @default("created")
  stakeMsat        BigInt // monto por jugador (msat)
  feePct           Int       @default(5) // fijado por Luna Negra
  victoryCondition String    @default("")
  roomId           String? // sala multijugador del juego (correlación, opcional)
  metadataJson     String? // metadata libre del proveedor (JSON serializado, opcional)
  depositDeadline  DateTime? // +10 min al crear
  resolveDeadline  DateTime? // +15 min al quedar ready
  contractEventId  String? // evento Nostr del contrato (inmutable)
  contractHash     String? // huella sha256 de los términos (verificada antes de pagar)
  resultEventId    String? // evento Nostr del resultado firmado
  createdAt        DateTime  @default(now())
  readyAt          DateTime?
  settledAt        DateTime?

  participants BetParticipant[]
  ledger       LedgerEntry[]

  @@index([status])
  @@index([depositDeadline])
  @@index([resolveDeadline])
}

model BetParticipant {
  id                 String    @id @default(cuid())
  betId              String
  bet                Bet       @relation(fields: [betId], references: [id])
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  npub               String // denormalizado para el contrato/display
  depositStatus      String    @default("pending") // pending | paid | refunded | failed
  depositInvoice     String? // bolt11
  depositPaymentHash String?   @unique
  result             String    @default("pending") // pending | won | lost | tie
  payoutStatus       String    @default("none") // none|pending|paid|failed|withdraw_pending|claimed|forfeited
  payoutMsat         BigInt?
  payoutDestination  String? // lud16 / LN address / NWC
  withdrawDeadline   DateTime? // +60 min para el QR de retiro
  createdAt          DateTime  @default(now())
  paidAt             DateTime?
  settledAt          DateTime?

  @@unique([betId, userId]) // una participación por usuario y apuesta
  @@index([betId])
}

model LedgerEntry {
  id             String   @id @default(cuid())
  betId          String
  bet            Bet      @relation(fields: [betId], references: [id])
  userId         String? // null = movimiento de la casa (fee/forfeit)
  user           User?    @relation(fields: [userId], references: [id])
  kind           String // deposit | payout | refund | fee | forfeit
  amountMsat     BigInt
  status         String   @default("pending") // pending | settled | failed
  paymentHash    String?
  idempotencyKey String   @unique // {kind}:{betId}:{userId} → guard anti-doble-gasto
  createdAt      DateTime @default(now())

  @@index([betId])
}
