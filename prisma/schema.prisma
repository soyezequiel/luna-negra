generator client {
  provider      = "prisma-client-js"
  // "native" para local + el target del runtime de Vercel (Amazon Linux, OpenSSL 3).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL: conexión con POOLER (para serverless en Vercel).
  // DIRECT_URL: conexión DIRECTA (sin pooler), usada por las migraciones.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  npub        String   @unique
  pubkey      String   @unique // hex
  // Cuentas custodiales (login por email con magic link): el usuario no trae una
  // identidad Nostr propia, así que Luna Negra le genera el keypair. `email` es
  // el identificador de login; `nsecEnc` es la clave privada cifrada en reposo
  // (AES-256-GCM, ver src/lib/crypto-vault.ts) que se le entrega al navegador al
  // loguear y se puede exportar desde el perfil. Null en cuentas Nostr normales.
  email       String?  @unique
  nsecEnc     String? // secret key cifrada (solo cuentas custodiales por email)
  displayName String?
  avatarUrl   String?
  // Código corto, estable y compartible para encontrar a otro miembro sin
  // exponer ni copiar su npub completa. La secuencia se limita a 6 dígitos.
  friendCode  Int      @unique @default(autoincrement())
  lud16       String? // Lightning Address para cobrar payouts (override del kind:0)
  // Destino de cobros de premios/payouts: "address" = cascada lud16 (Luna Negra
  // → kind:0); "nwc" = el wallet NWC del usuario (vive sólo en su navegador), así
  // que el server fuerza withdraw_pending y el cliente reclama por LNURL-withdraw.
  payoutMethod String  @default("address")
  createdAt   DateTime @default(now())
  lastSeen    DateTime @default(now())
  // Última vez que lanzó/jugó un juego (ordena la lista de amigos: los que
  // jugaron alguna vez van arriba). Null = nunca jugó.
  lastPlayedAt DateTime?
  // Marca "visto hasta" del centro de notificaciones (campanita). El feed se
  // deriva en lectura de tablas existentes (compras/zaps/reseñas/apuestas) +
  // comentarios Nostr; las que tengan timestamp posterior a esta marca cuentan
  // como no leídas. Null = nunca abrió el panel (todo lo reciente es nuevo).
  notificationsSeenAt DateTime?
  // Opt-in para ver juegos en beta (`Game.isBeta`). Por defecto los juegos beta
  // quedan ocultos del catálogo y de la ficha; el usuario activa esto en su perfil
  // para verlos y probarlos. El dueño del juego y el admin los ven siempre.
  showBetaGames Boolean @default(false)

  providers         Provider[]
  purchases         Purchase[]
  reviews           Review[]
  betParticipations BetParticipant[]
  ledgerEntries     LedgerEntry[]
  zapBetParticipations ZapBetParticipant[]
  zapLedgerEntries     ZapLedgerEntry[]
  dismissedNotifications DismissedNotification[]
}

// Notificación descartada por el usuario ("marcar leído y que se vaya"). El feed
// se deriva en lectura, así que no hay fila por notificación: guardamos solo la
// CLAVE estable del ítem descartado (NotifItem.id, p. ej. "comment:<eventId>",
// "purchase:<cuid>") y la filtramos del feed. Complementa la marca global
// `User.notificationsSeenAt` (no-leído) con un descarte individual.
model DismissedNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  key       String // NotifItem.id descartado
  createdAt DateTime @default(now())

  @@unique([userId, key])
  @@index([userId])
}

model Provider {
  id               String   @id @default(cuid())
  ownerId          String
  owner            User     @relation(fields: [ownerId], references: [id])
  name             String
  imageUrl         String? // imagen/avatar del proveedor (se muestra en la ficha del juego)
  lightningAddress String? // dirección Lightning para el payout (70%)
  status           String   @default("pending") // pending | approved
  // % del pozo que se lleva el dev (proveedor) al liquidar apuestas con ganador.
  // Es el default para todas sus apuestas; un juego puede overridearlo con
  // `Game.betDevFeePct`. Se ACOTA al tope global `PlatformSettings.betDevFeeMaxPct`
  // al crear la apuesta. Se SUMA al corte de la casa (`Bet.feePct`).
  betDevFeePct     Int      @default(0)
  webhookUrl       String? // URL para notificar eventos (purchase/bet/payout)
  webhookSecret    String? // secreto para firmar los webhooks (HMAC) — whsec_…
  // Oráculo gestionado: clave Nostr que Luna Negra custodia para firmar el
  // resultado/actividad en nombre del proveedor (así el game server solo usa su
  // API key). `oraclePubkey` (hex) es público y valida los eventos firmados;
  // `oracleSecretEnc` es el secreto cifrado en reposo (AES-256-GCM). Ver
  // src/lib/oracle-keys.ts y src/lib/crypto-vault.ts.
  oraclePubkey     String? // hex; contra esta clave se valida el evento de resultado
  oracleSecretEnc  String? // secreto cifrado (nunca se loguea ni se expone por API). NULL si oracleSelfSigned (Luna no custodia la clave BYO)
  oracleSelfSigned Boolean  @default(false) // true = clave de oráculo PROPIA del proveedor (BYO, keyless): el juego firma sus 1341; Luna no puede firmar por él. Ver oracle-keys.ts
  createdAt        DateTime @default(now())

  games               Game[]
  bets                Bet[]
  zapBets             ZapBet[]
  apiKeys             ApiKey[]
  gamePresence        GamePresence[]
  gameInvites         GameInvite[]
  gameLaunchRequests  GameLaunchRequest[]
  gameLaunchListeners GameLaunchListener[]
  integrationPings    IntegrationPing[]
  playerCountSamples  PlayerCountSample[]
  gamePlayClicks      GamePlayClick[]
  playSessions        PlaySession[]
}

// Sesión de juego para medir tiempo jugado ("12 h en tu registro", "sesión
// media X min"), derivada del heartbeat de presencia REST (§3, `POST /api/v1/
// presence`). Se abre en el primer latido de una racha y se cierra con el
// ÚLTIMO latido visto (no con "ahora") cuando pasa más de SESSION_GAP_MS sin
// uno nuevo — ver src/lib/play-session.ts. Los juegos que solo reportan clicks
// (sin heartbeat, §3 no integrado) NO generan filas acá: sin latidos no hay
// forma de saber cuánto duró la sesión sin inventar (mismo criterio que
// PlayerCountSample.source="clicks" en play-click.ts).
model PlaySession {
  id         String    @id @default(cuid())
  providerId String
  provider   Provider  @relation(fields: [providerId], references: [id])
  gameId     String?
  npub       String
  startedAt  DateTime  @default(now())
  lastBeatAt DateTime  @default(now())
  endedAt    DateTime?

  @@index([providerId, gameId, npub, endedAt])
  @@index([gameId, npub])
  @@index([endedAt])
}

// Muestra periódica del conteo de jugadores con presencia activa de un proveedor.
// La presencia (`GamePresence`) es efímera (TTL ~30s, sin histórico), así que para
// dibujar la curva "jugadores concurrentes en el tiempo" (estilo SteamDB) la
// muestreamos cada pocos minutos desde el tick in-process (ver
// src/lib/presence-sampler.ts y src/instrumentation.ts). OJO: `GamePresence` se
// llavea por (providerId, npub) — no tiene gameId —, así que el conteo es POR
// PROVEEDOR. Exacto si el proveedor tiene un solo juego; si tiene varios, la curva
// es compartida. La serie arranca vacía y crece de aquí en adelante.
model PlayerCountSample {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  // Juego al que se atribuye la muestra. null = a nivel proveedor (presencia legacy
  // que no manda `game`, o providers de un solo juego): la curva se comparte entre
  // los juegos del proveedor. Si viene seteado, la muestra es de ESE juego (la curva
  // ya no se mezcla con los otros juegos del proveedor).
  gameId     String?
  count      Int // npub distintos con presencia activa al momento del sample
  // npubs presentes en esa muestra: permite mostrar QUIÉN jugaba al pasar el mouse
  // por el punto, y distinguir las sesiones del dueño (para no inflar la curva con
  // las pruebas del propio proveedor). Capado a un máximo razonable por muestra.
  npubs      String[] @default([])
  // Fuente del conteo de esta muestra:
  //   "presence" → presencia real reportada por el game server (GamePresence).
  //   "clicks"   → puntos de apertura (GamePlayClick), para juegos que NO integraron
  //                la presencia (§3). Ver presence-sampler.ts y play-click.ts.
  source     String   @default("presence")
  sampledAt  DateTime @default(now())

  @@index([providerId, sampledAt])
  @@index([providerId, gameId, sampledAt])
}

// Click en "Jugar" desde la tienda, deduplicado por jugador con una ventana de
// sesión asumida. Sirve para ESTIMAR la curva de "jugadores concurrentes" de los
// juegos que NO integraron la presencia real (§3, POST /api/v1/presence): sin
// heartbeat del game server no sabemos cuánto dura la sesión, así que al hacer
// click marcamos al jugador como "jugando" por una ventana fija (PLAY_CLICK_TTL_MS)
// y los re-clicks dentro de esa ventana solo la renuevan (no inflan el conteo).
// Lo lee el sampler (presence-sampler.ts) SOLO para proveedores sin presencia
// integrada; los que sí la integran usan GamePresence (fuente de verdad). Se
// llavea por (gameId, npub) para granularidad por juego, pero el sampler dedup por
// (providerId, npub) igual que la presencia real. Las filas vencidas se purgan.
model GamePlayClick {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  gameId     String
  npub       String
  expiresAt  DateTime // now + PLAY_CLICK_TTL_MS (ventana de sesión asumida)
  updatedAt  DateTime @updatedAt

  @@unique([gameId, npub])
  @@index([providerId, expiresAt])
  @@index([expiresAt])
}

// Telemetría de integración: registra que un endpoint del contrato público
// (§1–§8 de la guía /dev) fue ejercido por el game server o el cliente del juego.
// Alimenta el panel "Integración" (proveedor y admin) para ver, de forma visual,
// qué interfaces de Luna Negra tiene cableadas cada juego y cuándo se usó cada
// una por última vez. No guarda payloads: solo el contador y los timestamps.
model PlatformSettings {
  id          String   @id @default("global")
  // % que retiene Luna Negra en ventas de juegos. El % del proveedor se guarda
  // por juego como `Game.revenueShare = 100 - storeFeePct`.
  storeFeePct Int      @default(30)
  // % que retiene Luna Negra al liquidar apuestas con ganador. Cada apuesta
  // guarda una copia en `Bet.feePct` para que el contrato firmado sea inmutable.
  betFeePct   Int      @default(5)
  // Tope máximo del corte del dev sobre las apuestas. El % que fije el proveedor
  // (`Provider.betDevFeePct` o `Game.betDevFeePct`) se acota a este valor al crear
  // la apuesta, para que el dev no deje al ganador con muy poco ni a la casa en rojo.
  betDevFeeMaxPct Int   @default(20)
  // Límites (en sats) del depósito LIBRE a la tesorería (tesoreria@<dominio>, el
  // LNURL-pay que cae al NWC). null = usar el default del entorno (TREASURY_*_SATS).
  treasuryMinSats Int?
  treasuryMaxSats Int?
  updatedAt   DateTime @default(now()) @updatedAt
}

model IntegrationPing {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  // "" = a nivel proveedor (presencia, social, webhooks, que no traen gameId);
  // si no, el cuid del juego al que se atribuye la llamada.
  gameId      String   @default("")
  // sso | purchase | presence | rooms | social | leaderboards | bets | webhooks
  feature     String
  count       Int      @default(0)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([providerId, gameId, feature])
  @@index([providerId])
}

// Presencia por-juego (proveedor), keyed por npub, TTL ~30s. La pobla el game
// server vía POST /api/v1/presence (Bearer API key). Distinta de RoomPresence,
// que es por sala/clientId y la maneja Luna Negra en su demo multijugador.
model GamePresence {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  npub       String
  // Juego en el que el jugador está presente AHORA. El heartbeat lo manda como
  // `game` (slug); si no lo manda (integración vieja) queda null = "algún juego del
  // proveedor". Un jugador está en un solo juego a la vez por proveedor, así que la
  // unicidad sigue siendo (providerId, npub): al cambiar de juego se actualiza acá.
  gameId     String?
  status     String // "in-game" | "online" (clave reservada de presentación)
  roomId     String?
  stateJson  String? // bolsa libre del juego (JSON serializado): puntaje, vidas, equipo…
  expiresAt  DateTime // now + 30s
  updatedAt  DateTime @updatedAt

  @@unique([providerId, npub])
  @@index([providerId])
  @@index([providerId, gameId, expiresAt])
  @@index([expiresAt])
}

// Presencia "online en la tienda": el cliente (navegador logueado) manda un
// heartbeat mientras tiene la web abierta y visible. Keyed por usuario (pubkey),
// TTL ~75s (>2× del heartbeat de 30s, para tolerar un ping perdido). Sirve para
// contar usuarios concurrentes NAVEGANDO la tienda — distinto de GamePresence,
// que es "jugando X". La pobla POST /api/me/presence (cookie de sesión). Ver
// src/lib/store-presence.ts.
model StorePresence {
  pubkey    String   @id // hex; un usuario = una fila
  npub      String
  expiresAt DateTime // now + STORE_PRESENCE_TTL_MS
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

// Muestreo del conteo de usuarios online en la tienda (StorePresence) para
// dibujar la curva "usuarios concurrentes en el tiempo" en el admin. Lo escribe
// el tick in-process (instrumentation.ts) cada minuto; las tomas sin nadie online
// no escriben fila (hueco = 0 al graficar). Mismo patrón que PlayerCountSample.
model StorePresenceSample {
  id        String   @id @default(cuid())
  count     Int // usuarios distintos online al momento de la muestra
  npubs     String[] @default([]) // quiénes (capado), para el tooltip "quién estaba"
  sampledAt DateTime @default(now())

  @@index([sampledAt])
}

// Buzón de invitaciones a sala que el proveedor envía vía POST /api/v1/invites;
// Luna Negra se las muestra al invitado (toast in-app). TTL ~1h, como las
// invitaciones por DM existentes.
model GameInvite {
  id         String    @id @default(cuid())
  providerId String
  provider   Provider  @relation(fields: [providerId], references: [id])
  fromNpub   String
  toNpub     String
  roomId     String
  inviteUrl  String // URL del deploy del juego (externa), p. ej. .../?join=AB12
  createdAt  DateTime  @default(now())
  expiresAt  DateTime // now + 1h
  seenAt     DateTime?

  @@index([toNpub, expiresAt])
}

// Orden pendiente para que un juego YA abierto entre a una sala cuando el usuario
// aceptó una invitación en Luna Negra. La consume el game server vía API key.
model GameLaunchRequest {
  id          String    @id @default(cuid())
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id])
  npub        String
  roomId      String
  inviteToken String
  // "luna-room" = sala hosteada por Luna; "room-link" = sala hosteada por el juego.
  kind        String    @default("luna-room")
  slug        String
  title       String
  gameUrl     String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?

  @@index([providerId, npub, expiresAt])
  @@index([expiresAt])
}

// Pestaña de juego viva que consulta ordenes pendientes. No alimenta NIP-38 ni
// la lista social de "jugando"; solo evita abrir otra pestaña al aceptar una
// invitación si el juego ya está escuchando.
model GameLaunchListener {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  npub       String
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime

  @@unique([providerId, npub])
  @@index([expiresAt])
}

// Claves de API del proveedor (auth server-to-server, ej. crear apuestas).
// Se guarda solo el hash; la clave en claro se muestra una sola vez al crearla.
model ApiKey {
  id         String    @id @default(cuid())
  providerId String
  provider   Provider  @relation(fields: [providerId], references: [id])
  // Juego al que queda acotada la clave (opcional). Si está seteado, las rutas de
  // crear apuesta (v1/v2) usan este gameId como default cuando el body no lo trae,
  // así el game server no necesita la env var LUNA_NEGRA_GAME_ID. null = clave a
  // nivel proveedor (el body debe seguir mandando gameId). Al borrar el juego el FK
  // se anula (la clave sigue viva, provider-wide).
  gameId     String?
  game       Game?     @relation(fields: [gameId], references: [id], onDelete: SetNull)
  name       String
  prefix     String // primeros chars, para mostrar (ej. "ln_sk_ab12cd")
  hash       String    @unique // sha256(key)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([providerId])
  @@index([gameId])
}

model Game {
  id                 String   @id @default(cuid())
  providerId         String
  provider           Provider @relation(fields: [providerId], references: [id])
  apiKeys            ApiKey[] // claves de API acotadas a este juego (back-relation)
  slug               String   @unique
  title              String
  description        String   @default("")
  categories         String[] @default([]) // slugs de categorías curadas (ver src/lib/categories.ts)
  priceSats          Int      @default(0) // 0 = gratis
  coverUrl           String?
  horizontalCoverUrl String?
  screenshots        String   @default("[]") // JSON array de URLs (portable SQLite/Postgres)
  videos             String   @default("[]") // JSON array de URLs de video (trailers), estilo screenshots
  gameUrl            String? // subdominio donde el proveedor hostea el juego
  status             String   @default("draft") // draft | in_review | published
  // Capacidad declarada por el proveedor: este juego soporta retos 1v1 (NGP,
  // NIP-17). Solo si es true Luna Negra muestra el botón "Retar" en el juego.
  // Declaración manual de capacidades NGP NO observables por el server (login
  // NIP-07/46, presencia NIP-38): el probador no puede verificarlas, así que el
  // proveedor declara si las integró. Mapa { [capKey]: boolean }; ver
  // MANUAL_CAP_KEYS en src/lib/integration-ngp.ts.
  manualCaps         Json?
  // Modo por capacidad de la columna intermedia: elige por cuál interfaz corre
  // cada capacidad migrable. Mapa { [capKey]: "luna" | "nostr" }. "nostr" = migrada
  // a Nostr Games Protocol (NGP) → la pata Luna (REST) se APAGA para este juego
  // y su endpoint devuelve 409 CAPABILITY_MIGRATED. Ausente o "luna" = interfaz Luna
  // dependiente (default retrocompatible). Solo capacidades de MIGRATABLE_CAPS
  // (identidad, marcador, presencia, bets). Ver src/lib/capability-mode.ts.
  capsMode           Json?
  // Juego en beta: sigue siendo un juego normal (publicado, comprable, jugable y
  // anunciado en Nostr), pero la tienda solo lo muestra a quien activó "ver juegos
  // beta" en su perfil (`User.showBetaGames`), más el dueño y el admin. Es ortogonal
  // a `status`: se marca/desmarca sin re-aprobar. Distinto de `admin_only` (oculto
  // para todos salvo admin/dueño).
  isBeta             Boolean  @default(false)
  revenueShare       Int      @default(70) // % para el proveedor
  // Override por juego del corte de Luna Negra en apuestas (admin). null = hereda
  // el global `PlatformSettings.betFeePct`.
  betFeePct          Int? // override del corte de la casa en apuestas (admin)
  // Override por juego del corte del dev en apuestas (proveedor). null = hereda el
  // default del proveedor `Provider.betDevFeePct`. Se acota al tope global.
  betDevFeePct       Int? // override del corte del dev en apuestas (proveedor)
  // Oráculo de ATESTACIONES (NGP kind:31338, spec §3.4): pubkey (hex) con la que
  // el game server del proveedor firma "en la sala X ganó Y". Declarada por el
  // proveedor con prueba de posesión (POST attestation-oracle). El artículo 30023
  // la publica como tag ["oracle", pk] — la DELEGACIÓN que un verificador cruza
  // contra el firmante del 31338. Es POR JUEGO y distinta de Provider.oraclePubkey
  // (el oráculo de APUESTAS, que NGE v2 fuerza a gestionado y puede rotar Luna):
  // esta clave la custodia el PROVEEDOR y Luna nunca firma con ella.
  attestationOraclePubkey String?
  // Artículo NIP-23 (kind:30023): la representación CANÓNICA del juego publicado
  // en Nostr (fuente de verdad). La DB es un caché write-through, reconciliable
  // por game-sync.ts. Comentarios y reseñas se cuelgan de la coordenada
  // (`nostrCoord`, tag `a`), estable entre ediciones.
  nostrEventId       String? // id del ÚLTIMO evento 30023 (cambia en cada edición)
  nostrPubkey        String? // pubkey que FIRMÓ el artículo (tienda o proveedor, según articleSigner)
  nostrCoord         String? // coordenada direccionable `30023:<pubkey>:<slug>` (root tag `a`)
  nostrPublishedAt   DateTime? // `published_at` original (se preserva entre ediciones)
  nostrUpdatedAt     DateTime? // created_at del último artículo cacheado (freshness del sync)
  // Quién firma el artículo NIP-23 de este juego. "store" = régimen legacy (la
  // tienda firma server-side con LUNA_NEGRA_NSEC, camino syncGameToNostr).
  // "provider" = el PROVEEDOR firma en su navegador (NIP-07/46/local) y la tienda
  // solo difunde el evento ya firmado — alinea con la spec NGP (la coordenada es
  // `30023:<pubkey-del-dev>:<slug>`). Flag EXPLÍCITO (no derivado de nostrPubkey
  // === storePubkey) porque antes de publicar nostrPubkey es null y porque la
  // clave de la tienda podría rotar sin reinterpretar juegos.
  articleSigner      String   @default("store") // "store" | "provider"
  // Evento kind:30023 YA FIRMADO por el proveedor, pendiente de difusión (lo firma
  // al enviar a revisión; el admin lo difunde a relays al aprobar). null = sin
  // firma pendiente. Se borra si el proveedor edita la ficha (la firma dejó de
  // corresponder a lo que el admin revisa).
  signedArticle      Json?
  // La ficha publicada en la DB tiene cambios que TODAVÍA no se firmaron ni
  // difundieron en Nostr (solo juegos provider-firmados ya publicados: el server
  // no puede re-firmar por el proveedor). El proveedor debe "Firmar y difundir".
  articleDirty       Boolean  @default(false)
  // Pubkey (hex) que firma los recibos de zap (kind 9735) del wallet LNURL del
  // dev de este juego. Se cachea en `zap/prepare` y se usa en la reconciliación
  // (zap-sync.ts) para validar que un recibo viene del wallet correcto. Si es
  // null, el dev todavía no tiene un address con soporte de zaps NIP-57.
  zapLnurlPubkey     String?
  createdAt          DateTime @default(now())

  purchases Purchase[]
  reviews   Review[]
  bets      Bet[]
  zapBets   ZapBet[]
  zaps      Zap[]
  comments  GameComment[]

  ngeCredential NgeCredential?
}

// Credencial NGE (Nostr Game Escrow) por juego: la "NWC del escrow". Luna genera
// un par de servicio, publica el bind event (kind:31340 `d`=bind:<pubkey>) y le
// entrega al dev la URI `nostr+nge://<escrow>?relay=…&secret=…` para pegar en
// NGE_CONNECTION. El secreto va CIFRADO (crypto-vault) para re-emitir la MISMA
// credencial de forma idempotente y rotarla. La `servicePubkey` es el oráculo del
// juego vía TOFU (queda en `ZapBet.oraclePubkey` al materializar el 1339). Ver
// docs/nge/ y src/lib/nge-credential.ts.
model NgeCredential {
  id               String    @id @default(cuid())
  gameId           String    @unique
  game             Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  servicePubkey    String    @unique // pubkey (hex) del oráculo/servicio del juego
  serviceSecretEnc String // secreto cifrado (AES-256-GCM); nunca se loguea
  createdAt        DateTime  @default(now())
  rotatedAt        DateTime? // última rotación (null = nunca rotada)
}

// Comentario (kind:1) de un juego, CACHEADO desde Nostr. La fuente de verdad es
// el evento Nostr firmado por el usuario (respuesta al anuncio del juego con el
// tag `t = lunanegra:game:<slug>`); esta tabla solo acelera el acceso para el
// centro de notificaciones (igual que `Zap` cachea los recibos 9735). La pobla
// la reconciliación in-process `comment-sync.ts`, deduplicando por `eventId`.
model GameComment {
  id           String   @id @default(cuid())
  eventId      String   @unique // id del kind:1 (dedup idempotente)
  gameId       String
  game         Game     @relation(fields: [gameId], references: [id])
  authorPubkey String // hex; pubkey del autor del comentario
  content      String // contenido crudo del evento (se recorta el pie al mostrar)
  createdAt    DateTime // created_at del evento Nostr
  recordedAt   DateTime @default(now())

  @@index([gameId])
  @@index([authorPubkey])
}

// Zap (propina NIP-57) verificado a un juego gratis. La fuente de verdad es el
// recibo de zap (kind 9735) firmado por el wallet del dev; lo levanta de relays
// la reconciliación (src/lib/zap-sync.ts) y lo deduplica por `receiptId`. De acá
// sale el "top de zappers" por juego y por dev (providerId denormalizado).
model Zap {
  id           String   @id @default(cuid())
  receiptId    String   @unique // id del evento 9735 (dedup idempotente)
  gameId       String
  game         Game     @relation(fields: [gameId], references: [id])
  providerId   String // denormalizado → top por dev (suma de todos sus juegos)
  zapperPubkey String // hex; del zap request (9734) embebido en el recibo
  amountSats   Int
  comment      String?
  zappedAt     DateTime // created_at del recibo 9735
  recordedAt   DateTime @default(now())

  @@index([gameId])
  @@index([providerId])
  @@index([zapperPubkey])
}

model Purchase {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  gameId       String
  game         Game      @relation(fields: [gameId], references: [id])
  amountSats   Int
  invoice      String? // bolt11
  paymentHash  String?
  status       String    @default("pending") // pending | paid | failed
  payoutStatus String    @default("none") // none | pending | paid | failed
  payoutHash   String?
  createdAt    DateTime  @default(now())
  paidAt       DateTime?

  @@unique([userId, gameId]) // un usuario posee un juego una sola vez (entitlement)
}

// Idempotencia de endpoints de dinero (header Idempotency-Key). Guarda la
// respuesta para devolverla en reintentos sin re-ejecutar la acción.
model IdempotencyKey {
  id         String   @id @default(cuid())
  scope      String // ej. providerId
  key        String
  statusCode Int? // null = en progreso (claim sin respuesta aún)
  response   String? // JSON del body
  createdAt  DateTime @default(now())

  @@unique([scope, key])
}

// Sala multijugador: registra al host original (identidad Nostr estable) para
// que los invitados sepan quién creó la sala, aunque el host se desconecte y
// la presencia efímera (RoomPresence) caduque. Una sala por (gameId, roomId).
model Room {
  id         String    @id @default(cuid())
  gameId     String
  roomId     String
  hostNpub   String
  hostPubkey String // hex
  // Latido del host: se sella al primer heartbeat del host. Sirve para no cerrar
  // la sala por "host ausente" antes de que el host haya llegado siquiera.
  hostSeenAt DateTime?
  // Si el host cierra el juego (leave explícito o presencia vencida) la sala se
  // cierra para siempre: nadie se readmite y los invitados reciben closed:true.
  closedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@unique([gameId, roomId])
  @@index([gameId])
}

// Presencia efímera de salas multijugador (demo). Polling + limpieza por TTL.
model RoomPresence {
  id        String   @id @default(cuid())
  roomId    String
  clientId  String // distingue navegadores/pestañas aunque compartan npub
  npub      String
  host      Boolean  @default(false)
  score     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, clientId])
  @@index([roomId])
}

// Estado compartido de una sala, para juegos SIN backend propio (Luna Negra
// hostea el "tablero común", estilo SetLobbyData de Steam). Bolsa key/value
// libre; la plataforma no interpreta su contenido. TTL corto: si nadie escribe
// por un rato, la sala se considera abandonada y se purga.
model RoomState {
  id        String   @id @default(cuid())
  roomId    String   @unique
  dataJson  String   @default("{}") // bolsa compartida (JSON serializado, last-write-wins por clave)
  version   Int      @default(0) // se incrementa en cada escritura compartida (CAS opcional / ETag)
  updatedAt DateTime @updatedAt
  expiresAt DateTime // now + TTL; se renueva en cada escritura

  @@index([expiresAt])
}

// Estado por jugador dentro de una sala (estilo SetLobbyMemberData de Steam): lo
// escribe el propio jugador con su invite token. Alimenta `members[]` del estado
// de la sala. TTL corto = roster vivo (cada POST actúa de heartbeat).
model RoomMemberState {
  id        String   @id @default(cuid())
  roomId    String
  npub      String
  stateJson String   @default("{}") // bolsa libre del jugador (JSON serializado)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime // now + TTL; se renueva en cada POST del jugador

  @@unique([roomId, npub])
  @@index([roomId])
  @@index([expiresAt])
}

// Marcador con nombre, genérico y por juego (el `name` lo elige el juego:
// "semanal", "clasico", …). OJO: un puntaje lo manda el CLIENTE y es
// FALSIFICABLE → sirve para MOSTRAR rankings (como Steam), NO para resolver
// apuestas (eso sigue viniendo del game server por /result).
model Leaderboard {
  id        String   @id @default(cuid())
  gameId    String
  name      String // lo elige el juego: "semanal", "clasico", …
  createdAt DateTime @default(now())
  scores    Score[]

  @@unique([gameId, name])
  @@index([gameId])
}

// Mejor puntaje por jugador en un marcador ("se queda el mejor": una fila por
// jugador). `updatedAt` marca cuándo fijó ese récord (filtro de la ventana week).
model Score {
  id            String      @id @default(cuid())
  leaderboardId String
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  npub          String
  score         Int
  // Procedencia NGP: si el récord vigente entró por un evento Nostr (kind:31337
  // firmado por el jugador), guardamos su id y pubkey. null = vino por REST 1.0.
  // Ver docs/nostr-games-protocol-implementacion.md y src/lib/score-sync.ts.
  sourceEventId String?
  sourcePubkey  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([leaderboardId, npub])
  @@index([leaderboardId, score])
  @@index([sourceEventId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  rating    Int // 1-5
  body      String   @default("")
  // Procedencia NGP: si esta reseña se reconcilió desde el kind:1 firmado que
  // publica publishGameReview (respuesta al artículo del juego), guardamos su
  // id. null = solo vino por el POST de la REST 1.0. Ver src/lib/review-sync.ts.
  sourceEventId String?
  createdAt DateTime @default(now())

  @@unique([userId, gameId]) // una reseña por usuario y juego
}

// Magic links de login por email ya canjeados. El token JWT trae un `jti` único;
// al canjearlo insertamos ese jti acá, y el unique constraint hace el consumo de
// un solo uso atómico (un segundo canje del mismo link choca y se rechaza). El
// barrido por `expiresAt` permite purgar filas viejas (el token ya no es válido).
model ConsumedMagicLink {
  jti       String   @id
  consumedAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// ───────────────────────── Apuestas / Escrow (Fase C) ─────────────────────────

model Bet {
  id               String    @id @default(cuid())
  gameId           String
  game             Game      @relation(fields: [gameId], references: [id])
  providerId       String
  provider         Provider  @relation(fields: [providerId], references: [id])
  // created | pending_deposits | ready | settling | settled |
  // refunding | cancelled_incomplete | cancelled_admin | refunded_timeout | voided
  status           String    @default("created")
  stakeMsat        BigInt // monto por jugador (msat)
  feePct           Int       @default(5) // corte de Luna Negra (fijado por la casa)
  devFeePct        Int       @default(0) // corte del dev (proveedor), resuelto y acotado al crear
  victoryCondition String    @default("")
  roomId           String? // sala multijugador del juego (correlación, opcional)
  metadataJson     String? // metadata libre del proveedor (JSON serializado, opcional)
  depositDeadline  DateTime? // +10 min al crear
  resolveDeadline  DateTime? // +15 min al quedar ready
  contractEventId  String? // evento Nostr del contrato (inmutable)
  contractHash     String? // huella sha256 de los términos (verificada antes de pagar)
  resultEventId    String? // evento Nostr del resultado firmado
  createdAt        DateTime  @default(now())
  readyAt          DateTime?
  settledAt        DateTime?

  participants BetParticipant[]
  ledger       LedgerEntry[]

  @@index([status])
  @@index([depositDeadline])
  @@index([resolveDeadline])
}

model BetParticipant {
  id                 String    @id @default(cuid())
  betId              String
  bet                Bet       @relation(fields: [betId], references: [id])
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  npub               String // denormalizado para el contrato/display
  depositStatus      String    @default("pending") // pending | paid | refunded | failed
  depositInvoice     String? // bolt11
  depositPaymentHash String?   @unique
  result             String    @default("pending") // pending | won | lost | tie
  payoutStatus       String    @default("none") // none|pending|paid|failed|withdraw_pending|claimed|forfeited
  payoutMsat         BigInt?
  payoutDestination  String? // lud16 / LN address / NWC
  withdrawDeadline   DateTime? // +60 min para el QR de retiro
  createdAt          DateTime  @default(now())
  paidAt             DateTime?
  settledAt          DateTime?

  @@unique([betId, userId]) // una participación por usuario y apuesta
  @@index([betId])
}

model LedgerEntry {
  id             String   @id @default(cuid())
  betId          String
  bet            Bet      @relation(fields: [betId], references: [id])
  userId         String? // null = movimiento de la casa (fee/forfeit)
  user           User?    @relation(fields: [userId], references: [id])
  kind           String // deposit | payout | refund | fee | forfeit
  amountMsat     BigInt
  status         String   @default("pending") // pending | settled | failed
  paymentHash    String?
  idempotencyKey String   @unique // {kind}:{betId}:{userId} → guard anti-doble-gasto
  createdAt      DateTime @default(now())

  @@index([betId])
}

// ─────────────── Apuestas v2 (zaps NIP-57) — convive con v1 ────────────────
// Espejo de Bet/BetParticipant/LedgerEntry, pero el dinero se mueve por zaps
// públicos: depósitos anclados (tag `e`) al contrato y premios como profile-zaps
// al ganador. La lógica pura (economía, hash, estados, invariante del ledger) se
// reutiliza de v1; acá solo cambian los rieles de pago (zap entrante/saliente) y
// la auditoría pública (recibos 9735 + nota de liquidación kind:1).

model ZapBet {
  id               String    @id @default(cuid())
  gameId           String
  game             Game      @relation(fields: [gameId], references: [id])
  providerId       String
  provider         Provider  @relation(fields: [providerId], references: [id])
  // Mismos estados que Bet (bet-state.ts): created | pending_deposits | ready |
  // settling | settled | refunding | cancelled_incomplete | cancelled_admin |
  // refunded_timeout | voided
  status           String    @default("created")
  stakeMsat        BigInt // monto por jugador (msat)
  feePct           Int       @default(5) // corte de Luna Negra (fijado por la casa)
  devFeePct        Int       @default(0) // corte del dev (proveedor), resuelto al crear
  victoryCondition String    @default("")
  roomId           String? // sala multijugador del juego (correlación, opcional)
  metadataJson     String? // metadata libre del proveedor (JSON serializado, opcional)
  depositDeadline  DateTime? // +10 min al crear
  resolveDeadline  DateTime? // +15 min al quedar ready
  anchorEventId    String?   @unique // evento Nostr del contrato = ancla de depósitos y liquidación
  anchorEventKind  Int? // kind del ancla (1 = post de la tienda / raíz humana NGP; 1339 = NGP puro P2P). Para el tag `K` (NIP-22) del comentario de participación
  contractHash     String? // huella sha256 de los términos (idéntica a v1, CONTRACT_MISMATCH)
  contractPubkey   String? // pubkey del firmante del contrato NGP kind:1339 (el "retador"). Autoriza el void pre-fondeo (cancel) por 1341. Null en apuestas v2 REST (no hay 1339)
  oraclePubkey     String? // pubkey del `oracle` declarado EN el 1339 (TOFU por-apuesta): contra esta se valida el 1341. Null en apuestas v2 REST (usa Provider.oraclePubkey gestionado)
  resultEventId    String? // evento Nostr del resultado firmado
  resultEventKind  Int? // kind del resultado (1341 = spec NGP; null = legado 30078). Para el nevent con kind-hint del detalle
  settleNoteId     String? // nota de liquidación kind:1 (resumen público anclado)
  // NGE (RPC): clientRef y visibility promovidos de metadataJson.nge a columnas
  // (las filas viejas conservan el JSON; nge-meta.ts lee con fallback).
  ngeClientRef     String? // clave de idempotencia del juego (create_bet.clientRef)
  ngeUnlisted      Boolean   @default(false) // visibility:"unlisted": omite sombra 31340 + nota social
  // Ventana de disputa (NGE spec §7.1): resultado fijado, payout diferido al tick.
  settleAt           DateTime?
  pendingWinnersJson String? // npubs ganadores fijados por report_result (JSON array)
  createdAt        DateTime  @default(now())
  readyAt          DateTime?
  settledAt        DateTime?

  participants ZapBetParticipant[]
  ledger       ZapLedgerEntry[]

  @@index([status])
  @@index([depositDeadline])
  @@index([resolveDeadline])
  @@index([settleAt])
}

model ZapBetParticipant {
  id                 String    @id @default(cuid())
  betId              String
  bet                ZapBet    @relation(fields: [betId], references: [id])
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  npub               String // denormalizado para el contrato/display
  pubkey             String // hex denormalizado (v2 lo necesita para tags p/e)
  ngeSeatId          String? // seatId que asignó el juego (mapeo asiento↔participante NGE; filas viejas: metadataJson.nge)
  // Depósito (zap entrante que Luna Negra recibe como receptor NIP-57)
  depositStatus      String    @default("pending") // pending | paid | refunded | failed
  depositZapRequest  String? // JSON del 9734 FIRMADO por el apostador (va en description del 9735)
  depositInvoice     String? // bolt11 emitido por el NWC del server
  depositPaymentHash String?   @unique
  depositReceiptId   String?   @unique // id del 9735 que Luna Negra firmó y publicó
  depositReceiptJson String? // recibo 9735 firmado completo (re-publicar si 0 relays)
  depositReceiptOk   Boolean   @default(false) // >=1 relay aceptó el recibo (retry en tick si false)
  // Comentario de participación (kind:1111 NIP-22 sobre el evento del contrato, FIRMADO
  // por el propio jugador). El payout del ganador se zapea a ESTE comentario (e), no al post.
  commentEventId     String?   @unique // id del kind:1111 (null hasta publicarse en ≥1 relay)
  commentEventJson   String? // evento firmado completo (guardado al pedir invoice; se publica al pagar)
  commentEventOk     Boolean   @default(false) // >=1 relay aceptó el comentario (retry en tick si false)
  // Resultado / payout (zap saliente que Luna Negra firma hacia el receptor)
  result             String    @default("pending") // pending | won | lost | tie
  payoutStatus       String    @default("none") // none|pending|paid|failed|withdraw_pending|claimed|forfeited
  payoutMsat         BigInt?
  payoutDestination  String? // lud16 / LN address / null
  payoutKind         String? // zap | lnurl | withdraw (cómo salió la plata)
  payoutZapRequestId String? // id del 9734 firmado por Luna Negra (si payoutKind=zap)
  payoutReceiptId    String? // id del 9735 emitido por el wallet del receptor (lo levanta el sync)
  withdrawDeadline   DateTime? // +60 min para el QR de retiro
  createdAt          DateTime  @default(now())
  paidAt             DateTime?
  settledAt          DateTime?

  @@unique([betId, userId]) // una participación por usuario y apuesta
  @@index([betId])
}

model ZapLedgerEntry {
  id             String   @id @default(cuid())
  betId          String
  bet            ZapBet   @relation(fields: [betId], references: [id])
  userId         String? // null = movimiento de la casa (fee/forfeit)
  user           User?    @relation(fields: [userId], references: [id])
  kind           String // deposit | payout | refund | fee | dev_fee | forfeit
  amountMsat     BigInt
  status         String   @default("pending") // pending | settled | failed
  paymentHash    String?
  zapRequestId   String? // id del 9734 del movimiento
  zapReceiptId   String? // id del 9735 del movimiento
  idempotencyKey String   @unique // claves canónicas como v1: {kind}:{betId}[:{userId}]
  createdAt      DateTime @default(now())

  @@index([betId])
}
