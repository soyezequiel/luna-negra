# Copiá este archivo a .env.docker y completá. Luego:
#   docker compose --env-file .env.docker up -d --build
#
# NOTA: DATABASE_URL y DIRECT_URL NO van acá: el docker-compose las fija solo,
# apuntando al Postgres del propio compose. Si las ponés, se ignoran.

# --- Postgres (la app se conecta a estos vía el servicio "postgres") ---
POSTGRES_USER=luna
POSTGRES_PASSWORD=cambia-esta-password
POSTGRES_DB=luna

# --- Auth (OBLIGATORIO) ---
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Cloudflare Tunnel ---
# Token del túnel con nombre (dominio estable). Ver docker/README.md.
# Dejalo vacío si vas a usar el quick tunnel (override .quicktunnel.yml).
TUNNEL_TOKEN=

# URL pública canónica (la del túnel, p. ej. https://lunanegra.tudominio.com).
# Se usa en los links de los anuncios de juegos en Nostr. Opcional.
NEXT_PUBLIC_SITE_URL=

# Cargar datos de ejemplo en el PRIMER arranque (prisma db seed). true/false.
SEED_ON_START=false

# --- Backups automáticos del Postgres (servicio "backup") ---
# Cada cuántas horas hace pg_dump, y cuántas copias conserva en ./backups.
# Default: cada 6h, 28 copias (≈ 1 semana). Copiá ./backups a otro lado igual.
BACKUP_INTERVAL_HOURS=6
BACKUP_KEEP=28

# --- Obligatorio en producción ---
# Clave privada ES256 (JWK) para firmar tokens de dev (entitlement/invite). Sin
# esto, invitar amigos y lanzar juegos fallan con 500. Generar con:
#   node -e "import('jose').then(async j=>{const{privateKey}=await j.generateKeyPair('ES256',{extractable:true});const k=await j.exportJWK(privateKey);k.kid='ln-1';k.alg='ES256';k.use='sig';console.log(JSON.stringify(k))})"
LN_SIGNING_JWK=

# --- Opcionales (mismos nombres que .env.example; lo que pongas se pasa al contenedor) ---
# RESEND_API_KEY=
# EMAIL_FROM=
# NWC_CONNECTION_STRING=
# ADMIN_PUBKEY=
# DISCORD_WEBHOOK_URL=
# DISCORD_ALERT_WEBHOOK_URL=
# DISCORD_ZAP_WEBHOOK_URL=
# STORE_FEE_PCT=
# BLOB_READ_WRITE_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# LUNA_NEGRA_NSEC=
# ORACLE_ENC_KEY=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
